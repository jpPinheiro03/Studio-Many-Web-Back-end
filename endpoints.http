Content-Type: application/json
Authorization: Bearer {{token}}

{
  "clienteId": 1,
  "servicoId": 1,
  "funcionarioId": 1,
  "dataHoraInicio": "2026-04-01T10:00:00",
  "dataHoraFim": "2026-04-01T11:00:00",
